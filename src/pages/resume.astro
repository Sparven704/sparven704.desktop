---
import profile from "../data/profile.json";
import education from "../data/education.json";
import experience from "../data/experience.json";
import skills from "../data/skills.json";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Arvid - Resume</title>
  </head>
  <body class="home-desktop flex flex-col items-center min-h-screen pb-[30px]">
    <main
      class="flex flex-col justify-start items-center container bg-[#c0c0c0] max-w-3xl mt-10 mx-10 mb-10 border-2 border-black border-t-[#dfdfdf] border-l-[#dfdfdf] shadow-[4px_4px_0_0_#000]"
    >
      <!-- Windows 98 title bar - gradient -->
      <div
        class="flex flex-row justify-between items-center bg-[linear-gradient(90deg,navy,#1084d0)] w-full h-6 px-1"
      >
        <p class="text-white text-xs font-bold truncate">C:\files\resume</p>
        <div class="flex gap-0.5 shrink-0">
          <!-- Minimize -->
          <button
            class="win95-raised w-4 h-3.5 flex items-center justify-center text-black hover:bg-[#d4d0c8]"
          >
            <div class="w-2 h-0.5 bg-black"></div>
          </button>
          <!-- Maximize -->
          <button
            class="win95-raised w-4 h-3.5 flex items-center justify-center text-black hover:bg-[#d4d0c8]"
          >
            <div class="w-2 h-2 border border-black"></div>
          </button>
          <!-- Close - red -->
          <button
            class="win95-raised w-4 h-3.5 flex items-center justify-center text-white text-xs font-bold bg-[#c00000] border border-[#c00000] hover:bg-[#ff0000]"
          >
            x
          </button>
        </div>
      </div>

      <!-- 3D recessed separator line -->
      <div class="win98-separator w-full"></div>

      <!-- Navigation buttons -->
      <div class="flex gap-2 p-2 bg-[#c0c0c0] w-full">
        <a
          href="/"
          class="win95-raised px-3 py-1 text-sm font-normal text-black no-underline hover:bg-[#d4d0c8]"
        >
          ← back
        </a>
        <a
          href="/"
          class="win95-raised px-3 py-1 text-sm font-normal text-black no-underline hover:bg-[#d4d0c8]"
        >
          home
        </a>
      </div>

      <!-- Main content area - professional CV in Windows 98 style -->
      <section
        class="main-content m-2 p-4 pt-2 w-[calc(100%-1rem)] bg-[#D4D0C8]"
      >
        <!-- Profile header -->
        <header class="cv-profile-header">
          <h1 class="cv-name">{profile.name}</h1>
          <p class="cv-title">{profile.title}</p>
          <div class="win95-inset p-2 w-full">
            <p class="cv-contact">
              {profile.contact.email} · {profile.contact.location}
            </p>
            <div class="flex gap-2 mt-2 flex-wrap">
              <a
                href={profile.contact.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="win95-raised px-3 py-1.5 text-sm font-bold text-black no-underline hover:bg-[#d4d0c8] inline-block"
              >
                LinkedIn
              </a>
              <a
                href={profile.contact.github}
                target="_blank"
                rel="noopener noreferrer"
                class="win95-raised px-3 py-1.5 text-sm font-bold text-black no-underline hover:bg-[#d4d0c8] inline-block"
              >
                GitHub
              </a>
            </div>
          </div>
        </header>

        <!-- Summary -->
        <h2 class="cv-section-title">Summary</h2>
        <div class="win95-inset p-3 w-full">
          <p class="cv-summary">{profile.summary}</p>
          <p class="cv-summary-subtitle font-bold mt-3 mb-2">Core Experience</p>
          <ul class="cv-core-experience">
            {profile.coreExperience.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>

        <div class="cv-section-divider"></div>

        <!-- Experience -->
        <h2 class="cv-section-title">Experience</h2>
        {
          experience.map((ex) => (
            <div class="cv-experience-item">
              <div class="cv-experience-header">
                <span class="cv-experience-company">{ex.name}</span>
                <span class="cv-experience-role">— {ex.specification}</span>
                <span class="win95-inset px-2 py-0.5 inline-block">
                  <span class="cv-experience-duration font-mono">{ex.duration}</span>
                </span>
              </div>
              {ex.highlights && (
                <ul class="cv-highlights">
                  {ex.highlights.map((h) => (
                    <li>{h}</li>
                  ))}
                </ul>
              )}
              {ex.technologies && (
                <div class="cv-technologies">
                  {ex.technologies.map((tech) => (
                    <span class="cv-tech-tag">{tech}</span>
                  ))}
                </div>
              )}
            </div>
          ))
        }

        <div class="cv-section-divider"></div>

        <!-- Skills -->
        <h2 class="cv-section-title">Technical Skills</h2>
        <div class="cv-skills-grid">
          {
            skills.map((group) => (
              <div class="cv-skill-category win95-inset p-2">
                <p class="cv-skill-category-name">{group.category}</p>
                <ul class="cv-skill-list">
                  {group.skills.map((skill) => (
                    <li>{skill}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>

        <div class="cv-section-divider"></div>

        <!-- Education -->
        <h2 class="cv-section-title">Education</h2>
        {
          education.map((e) => (
            <div class="cv-education-item">
              <p class="cv-education-school">{e.name}</p>
              <p class="cv-education-program">{e.specification}</p>
              <span class="win95-inset px-2 py-0.5 inline-block mt-1">
                <span class="cv-education-duration font-mono">{e.duration}</span>
              </span>
            </div>
          ))
        }
      </section>
    </main>

    <!-- Windows 98 taskbar -->
    <footer class="win98-taskbar">
      <button
        type="button"
        id="start-btn"
        class="win98-raised win98-start-btn text-black overflow-visible ml-1"
        aria-expanded="false"
        aria-haspopup="true"
      >
        <img
          src="/windows-98-logo.png"
          alt="Windows 98"
          class="w-6 h-6 shrink-0 object-contain -ml-0.5"
        />
        Start
      </button>
    </footer>

    <!-- Windows 98 start menu -->
    <div
      id="start-menu"
      class="win98-start-menu"
      role="menu"
      aria-label="Start menu"
    >
      <div class="win98-start-menu-sidebar">
        <span class="win98-start-menu-branding">Windows98</span>
      </div>
      <div class="win98-start-menu-content">
        <a href="/" class="win98-start-menu-item" role="menuitem">
          <span class="win98-start-menu-item-icon">🏠</span>
          <span class="win98-start-menu-item-text">Home</span>
        </a>
        <a href="/resume" class="win98-start-menu-item" role="menuitem">
          <span class="win98-start-menu-item-icon">📁</span>
          <span class="win98-start-menu-item-text">Resume</span>
        </a>
        <button type="button" class="win98-start-menu-item" role="menuitem">
          <span class="win98-start-menu-item-icon">🌐</span>
          <span class="win98-start-menu-item-text">Windows Update</span>
        </button>
        <button type="button" class="win98-start-menu-item" role="menuitem">
          <span class="win98-start-menu-item-icon">📁</span>
          <span class="win98-start-menu-item-text">Programs</span>
          <span class="win98-start-menu-item-arrow">›</span>
        </button>
        <button type="button" class="win98-start-menu-item" role="menuitem">
          <span class="win98-start-menu-item-icon">★</span>
          <span class="win98-start-menu-item-text">Favorites</span>
          <span class="win98-start-menu-item-arrow">›</span>
        </button>
        <button type="button" class="win98-start-menu-item" role="menuitem">
          <span class="win98-start-menu-item-icon">📁</span>
          <span class="win98-start-menu-item-text">Documents</span>
          <span class="win98-start-menu-item-arrow">›</span>
        </button>
        <button type="button" class="win98-start-menu-item" role="menuitem">
          <span class="win98-start-menu-item-icon">⚙</span>
          <span class="win98-start-menu-item-text">Settings</span>
          <span class="win98-start-menu-item-arrow">›</span>
        </button>
        <button type="button" class="win98-start-menu-item" role="menuitem">
          <span class="win98-start-menu-item-icon">🔍</span>
          <span class="win98-start-menu-item-text">Find</span>
          <span class="win98-start-menu-item-arrow">›</span>
        </button>
        <button type="button" class="win98-start-menu-item" role="menuitem">
          <span class="win98-start-menu-item-icon">?</span>
          <span class="win98-start-menu-item-text">Help</span>
        </button>
        <div class="win98-start-menu-divider"></div>
        <button type="button" class="win98-start-menu-item" role="menuitem">
          <span class="win98-start-menu-item-icon">⏳</span>
          <span class="win98-start-menu-item-text">Run...</span>
        </button>
        <div class="win98-start-menu-divider"></div>
        <button type="button" class="win98-start-menu-item" role="menuitem">
          <span class="win98-start-menu-item-icon">🔑</span>
          <span class="win98-start-menu-item-text">Log Off...</span>
        </button>
        <button type="button" class="win98-start-menu-item" role="menuitem">
          <span class="win98-start-menu-item-icon" style="color: #c00000;"
            >⏻</span
          >
          <span class="win98-start-menu-item-text">Shut Down...</span>
        </button>
      </div>
    </div>

    <script>
      const startBtn = document.getElementById("start-btn")!;
      const startMenu = document.getElementById("start-menu")!;

      function toggleStartMenu() {
        const isOpen = startMenu.classList.toggle("open");
        startBtn.classList.toggle("pressed", isOpen);
        startBtn.setAttribute("aria-expanded", String(isOpen));
      }

      function closeStartMenu() {
        startMenu.classList.remove("open");
        startBtn.classList.remove("pressed");
        startBtn.setAttribute("aria-expanded", "false");
      }

      startBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        toggleStartMenu();
      });

      document.addEventListener("click", () => closeStartMenu());

      startMenu.addEventListener("click", (e) => e.stopPropagation());
    </script>
  </body>
</html>
