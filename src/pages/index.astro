---
import "../styles/global.css";
const base = import.meta.env.BASE_URL;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={base + "computer_explorer_cool-0.png"}
    />
    <link rel="icon" href={base + "computer_explorer_cool-0.png"} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>sys/init - Loading</title>
  </head>
  <body class="loading-screen">
    <div class="loading-window">
      <div
        class="flex flex-row justify-between items-center bg-[linear-gradient(90deg,navy,#1084d0)] w-full h-6 px-1"
      >
        <p class="text-white text-xs font-bold truncate">sys/init</p>
        <div class="flex gap-0.5 shrink-0">
          <button
            class="win95-raised w-4 h-3.5 flex items-center justify-center text-black"
          >
            <div class="w-2 h-0.5 bg-black"></div>
          </button>
          <button
            class="win95-raised w-4 h-3.5 flex items-center justify-center text-black"
          >
            <div class="w-2 h-2 border border-black"></div>
          </button>
          <button
            class="win95-raised w-4 h-3.5 flex items-center justify-center text-black"
          >
            <svg class="win98-close-x" viewBox="0 0 10 10" fill="none">
              <line x1="1" y1="1" x2="9" y2="9" />
              <line x1="9" y1="1" x2="1" y2="9" />
            </svg>
          </button>
        </div>
      </div>
      <div class="loading-content">
        <div id="loading-steps"></div>
        <a href={base + "home"} class="loading-continue-btn win95-raised"> continue </a>
      </div>
    </div>

    <script>
      const steps = [
        "[0.000] loading sparven704.desktop...",
        "[0.013] mounting /dev/audio",
        "[0.029] initializing 98.css",
        "[0.037] sparven.service started",
        "[0.044] all systems nominal",
      ];

      const container = document.getElementById("loading-steps")!;

      async function typeText(
        element: HTMLElement,
        text: string,
        speed: number = 30,
      ) {
        return new Promise<void>((resolve) => {
          let i = 0;
          element.textContent = "";
          const interval = setInterval(() => {
            if (i < text.length) {
              element.textContent += text[i];
              i++;
            } else {
              clearInterval(interval);
              resolve();
            }
          }, speed);
        });
      }

      async function runLoading() {
        for (const step of steps) {
          const line = document.createElement("div");
          line.className = "loading-line";
          const bracketEnd = step.indexOf("] ");
          const timestamp = bracketEnd >= 0 ? step.slice(0, bracketEnd + 2) : "";
          const message = bracketEnd >= 0 ? step.slice(bracketEnd + 2) : step;
          const timestampSpan = document.createElement("span");
          timestampSpan.className = "loading-timestamp";
          timestampSpan.textContent = timestamp;
          const messageSpan = document.createElement("span");
          line.appendChild(timestampSpan);
          line.appendChild(messageSpan);
          container.appendChild(line);
          await typeText(messageSpan, message, 25);
        }
      }

      runLoading();
    </script>
  </body>
</html>
